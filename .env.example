# ─── DATABASE ────────────────────────────────────────────────
# Neon PostgreSQL — same project as SnapFury or create a new one
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ─── STRIPE ──────────────────────────────────────────────────
# Get these from stripe.com/dashboard
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Create two one-time payment products in Stripe dashboard:
# Product 1: ClipFury Pro Founder — $8
# Product 2: ClipFury Pro — $15
STRIPE_FOUNDER_PRICE_ID="price_..."
STRIPE_REGULAR_PRICE_ID="price_..."

# ─── EMAIL ───────────────────────────────────────────────────
# Resend — free tier covers early stage (resend.com)
RESEND_API_KEY="re_..."

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://clipfury.net"
